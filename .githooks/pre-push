#!/usr/bin/env bash
# Pre-Push Hook: fmt + clippy lokal pruefen bevor gepusht wird.
set -e

echo "=== Pre-Push: cargo fmt --check ==="
cargo fmt --all -- --check || {
    echo "❌ Formatierung fehlerhaft. Bitte 'cargo fmt' ausfuehren."
    exit 1
}

echo "=== Pre-Push: cargo clippy ==="
cargo clippy --workspace --exclude fs25_auto_drive_host_bridge_ffi --all-targets --target x86_64-unknown-linux-gnu -- -D warnings || {
    echo "❌ Clippy-Fehler. Bitte beheben."
    exit 1
}

if rustup target list --installed | grep -q '^x86_64-pc-windows-gnu$'; then
    cargo clippy --workspace --exclude fs25_auto_drive_host_bridge_ffi --all-targets --target x86_64-pc-windows-gnu -- -D warnings || {
        echo "❌ Clippy-Fehler fuer Windows-Target. Bitte beheben."
        exit 1
    }
else
    echo "ℹ️  Windows-Target x86_64-pc-windows-gnu nicht installiert, Windows-Clippy lokal uebersprungen."
fi

echo "✅ fmt + clippy OK"
